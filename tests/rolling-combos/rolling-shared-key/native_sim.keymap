/*
 * Test: rolling-shared-key
 *
 * Two combos sharing key position 1:
 *   combo_x: positions <0 1> → X
 *   combo_y: positions <1 2> → Y
 *
 * This is the core rolling-combos test.  Press 0+1 to activate combo_x,
 * then press 2 while key 1 is still held.  Combo_y should detect that
 * position 1 is borrowed from the active combo_x and activate immediately.
 *
 * Sequence:
 *   press(0, 0ms), press(1, 10ms),       -- combo_x activates
 *   press(2, 10ms),                       -- combo_y activates (key 1 borrowed)
 *   release(0, 200ms),                    -- combo_x releases (non-slow-release)
 *   release(1, 10ms),                     -- released from both active combos
 *   release(2, 10ms)                      -- combo_y fully released
 *
 * Expected: press X, press Y, release X, release Y
 */

#include <dt-bindings/zmk/keys.h>
#include <behaviors.dtsi>
#include <dt-bindings/zmk/kscan_mock.h>

/ {
    rolling_combos {
        compatible = "zmk,rolling-combos";
        combo_x {
            timeout-ms = <50>;
            key-positions = <0 1>;
            bindings = <&kp X>;
        };
        combo_y {
            timeout-ms = <50>;
            key-positions = <1 2>;
            bindings = <&kp Y>;
        };
    };

    keymap {
        compatible = "zmk,keymap";
        default_layer {
            bindings = <
                &kp A &kp B
                &kp C &kp D
            >;
        };
    };
};

&kscan {
    events = <
        ZMK_MOCK_PRESS(0, 0, 0)
        ZMK_MOCK_PRESS(0, 1, 10)
        ZMK_MOCK_PRESS(1, 0, 10)
        ZMK_MOCK_RELEASE(0, 0, 200)
        ZMK_MOCK_RELEASE(0, 1, 10)
        ZMK_MOCK_RELEASE(1, 0, 10)
    >;
};
